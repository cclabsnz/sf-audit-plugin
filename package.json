{
  "name": "@cclabsnz/sf-audit",
  "version": "1.0.0",
  "description": "Salesforce Security Audit — native sf plugin",
  "type": "module",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/jest test/unit --passWithNoTests",
    "prepack": "npm run build",
    "clean": "rm -rf lib"
  },
  "dependencies": {
    "@oclif/core": "^4",
    "@salesforce/core": "^8",
    "@salesforce/sf-plugins-core": "^12",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/jest": "^29",
    "@types/node": "^22",
    "jest": "^29",
    "ts-jest": "^29",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cclabsnz/sf-audit-plugin.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "oclif": {
    "bin": "sf",
    "dirname": "sf",
    "commands": "./lib/commands",
    "pluginType": "jit",
    "flexibleTaxonomy": true,
    "devPlugins": [],
    "topics": {
      "audit": {
        "description": "Salesforce security audit commands"
      }
    }
  },
  "files": [
    "/lib",
    "/messages",
    "/config",
    "!/lib/**/*.map"
  ]
}
